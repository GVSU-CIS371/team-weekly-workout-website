    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Edge (FitCore)",
            "request": "launch",
            "type": "msedge",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/FitCore"
        },
        {
            "name": "Attach to Edge (FitCore)",
            "request": "attach",
            "type": "msedge",
            "port": 9222,
            "webRoot": "${workspaceFolder}/FitCore"
        }
    ]
}